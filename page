<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8"/>
<meta name="viewport" content="width=device-width, initial-scale=1.0"/>
<title>RYNS — Premium Clothing, Varanasi</title>
<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,700;0,900;1,400;1,700&family=Outfit:wght@300;400;500;600&display=swap" rel="stylesheet"/>
<style>
/* ── TOKENS ── */
:root{
  --white:#fafaf8;
  --off:#f2ede4;
  --ink:#111210;
  --mid:#5a5650;
  --gold:#b8922a;
  --gold-lt:#d4b060;
  --rust:#c04a28;
  --border:#e2ddd4;
  --ig-grad:linear-gradient(135deg,#833ab4 0%,#fd1d1d 50%,#fcb045 100%);
}
*{margin:0;padding:0;box-sizing:border-box}
html{scroll-behavior:smooth;font-size:16px}
body{
  background:var(--white);color:var(--ink);
  font-family:'Outfit',sans-serif;
  overflow-x:hidden;
  cursor:none;
}

/* ── CUSTOM CURSOR ── */
#cur{
  width:12px;height:12px;background:var(--ink);border-radius:50%;
  position:fixed;pointer-events:none;z-index:9999;
  transform:translate(-50%,-50%);transition:transform .08s,width .2s,height .2s,background .2s;
}
#cur-ring{
  width:36px;height:36px;border:1px solid rgba(17,18,16,.3);border-radius:50%;
  position:fixed;pointer-events:none;z-index:9998;
  transform:translate(-50%,-50%);transition:transform .18s ease-out,width .2s,height .2s;
}
body:hover #cur{transform:translate(-50%,-50%) scale(1)}

/* ── NAV ── */
nav{
  position:fixed;top:0;left:0;right:0;z-index:500;
  display:flex;align-items:center;justify-content:space-between;
  padding:1.1rem 3.5rem;
  background:rgba(250,250,248,.92);
  backdrop-filter:blur(16px);
  border-bottom:1px solid var(--border);
}
.nav-logo{
  font-family:'Playfair Display',serif;font-size:1.55rem;
  font-weight:900;letter-spacing:.08em;color:var(--ink);text-decoration:none;
}
.nav-logo span{color:var(--gold)}
.nav-links{display:flex;gap:2.5rem;list-style:none}
.nav-links a{
  font-size:.75rem;font-weight:500;letter-spacing:.14em;
  text-transform:uppercase;color:var(--mid);text-decoration:none;
  transition:color .2s;position:relative;
}
.nav-links a::after{
  content:'';position:absolute;bottom:-4px;left:0;right:0;
  height:1px;background:var(--gold);
  transform:scaleX(0);transform-origin:left;transition:transform .25s;
}
.nav-links a:hover{color:var(--ink)}
.nav-links a:hover::after{transform:scaleX(1)}
.nav-ig-btn{
  display:flex;align-items:center;gap:.5rem;
  background:var(--ig-grad);
  color:#fff;padding:.42rem 1.1rem;border-radius:30px;
  font-size:.7rem;font-weight:600;letter-spacing:.07em;text-transform:uppercase;
  text-decoration:none;transition:opacity .2s,transform .2s;
}
.nav-ig-btn:hover{opacity:.88;transform:translateY(-1px)}

/* ── HERO ── */
.hero{
  min-height:100vh;display:grid;
  grid-template-columns:55% 45%;
  padding-top:5rem;
  position:relative;overflow:hidden;
}
/* left */
.hero-l{
  display:flex;flex-direction:column;justify-content:center;
  padding:4rem 4rem 4rem 5rem;
  position:relative;z-index:2;
}
.hero-chip{
  display:inline-flex;align-items:center;gap:.5rem;
  background:var(--off);border:1px solid var(--border);
  padding:.38rem 1rem;border-radius:30px;width:fit-content;
  font-size:.68rem;font-weight:600;letter-spacing:.1em;text-transform:uppercase;color:var(--mid);
  margin-bottom:2rem;
}
.hero-chip-dot{width:6px;height:6px;border-radius:50%;background:#2ecc71;animation:blink 2s infinite}
@keyframes blink{0%,100%{opacity:1}50%{opacity:.3}}

h1.hero-title{
  font-family:'Playfair Display',serif;
  font-size:clamp(3.5rem,7vw,7rem);
  font-weight:900;line-height:.95;
  color:var(--ink);margin-bottom:1rem;
  animation:slideUp .8s .1s both;
}
h1.hero-title em{
  font-style:italic;color:var(--gold);
  display:block;font-weight:400;
}
.hero-sub{
  font-size:1rem;color:var(--mid);line-height:1.75;
  max-width:380px;margin-bottom:2.5rem;font-weight:300;
  animation:slideUp .8s .2s both;
}
.hero-actions{display:flex;gap:1rem;flex-wrap:wrap;animation:slideUp .8s .3s both}

/* ── BUTTONS ── */
.btn{
  padding:.85rem 2rem;font-size:.76rem;font-weight:600;
  letter-spacing:.14em;text-transform:uppercase;
  text-decoration:none;border:none;cursor:none;
  display:inline-block;font-family:'Outfit',sans-serif;
  transition:transform .2s,box-shadow .2s;
}
.btn:hover{transform:translateY(-3px)}
.btn-dark{
  background:var(--ink);color:var(--white);
  box-shadow:0 8px 24px rgba(17,18,16,.15);
}
.btn-dark:hover{box-shadow:0 16px 40px rgba(17,18,16,.25)}
.btn-out{
  background:transparent;color:var(--ink);
  border:1.5px solid var(--ink);
}
.btn-out:hover{background:var(--ink);color:var(--white)}
.btn-ig-big{
  background:var(--ig-grad);color:#fff;
  box-shadow:0 8px 24px rgba(131,58,180,.2);
}
.btn-ig-big:hover{box-shadow:0 16px 40px rgba(131,58,180,.35)}

.hero-nums{
  display:flex;gap:2.5rem;margin-top:3rem;
  padding-top:2.5rem;border-top:1px solid var(--border);
  animation:slideUp .8s .4s both;
}
.num-v{font-family:'Playfair Display',serif;font-size:2rem;font-weight:700;color:var(--ink)}
.num-l{font-size:.68rem;font-weight:500;letter-spacing:.12em;text-transform:uppercase;color:var(--mid);margin-top:.2rem}

/* hero right — video + 3D shirt */
.hero-r{
  position:relative;overflow:hidden;
  background:var(--off);
}
.hero-video{
  width:100%;height:100%;object-fit:cover;display:block;
}
.hero-r-overlay{
  position:absolute;inset:0;
  background:linear-gradient(to right,rgba(250,250,248,.18) 0%,transparent 40%);
  pointer-events:none;
}
/* Floating label on video */
.vid-label{
  position:absolute;bottom:2rem;left:2rem;
  background:rgba(250,250,248,.92);
  backdrop-filter:blur(12px);
  border:1px solid var(--border);
  padding:1rem 1.4rem;
}
.vid-label-title{font-family:'Playfair Display',serif;font-size:1rem;font-weight:700;color:var(--ink)}
.vid-label-sub{font-size:.68rem;font-weight:500;letter-spacing:.1em;text-transform:uppercase;color:var(--mid);margin-top:.2rem}
.vid-ig-tag{
  position:absolute;top:1.5rem;right:1.5rem;
  background:var(--ig-grad);color:#fff;
  padding:.4rem .9rem;border-radius:20px;
  font-size:.67rem;font-weight:700;letter-spacing:.07em;
}

@keyframes slideUp{from{opacity:0;transform:translateY(24px)}to{opacity:1;transform:translateY(0)}}

/* ── MARQUEE ── */
.ticker{
  background:var(--ink);padding:.6rem 0;overflow:hidden;
  position:relative;z-index:2;
}
.ticker-track{
  display:flex;gap:3rem;white-space:nowrap;
  animation:tickerMove 22s linear infinite;
  font-family:'Playfair Display',serif;font-style:italic;
  font-size:1rem;color:rgba(255,255,255,.55);letter-spacing:.04em;
}
.ticker-track b{color:var(--gold-lt);font-style:normal;font-family:'Outfit',sans-serif;font-size:.72rem;font-weight:600;letter-spacing:.2em;text-transform:uppercase}
@keyframes tickerMove{from{transform:translateX(0)}to{transform:translateX(-50%)}}

/* ── SECTION WRAP ── */
.wrap{padding:7rem 5rem;position:relative}
.s-tag{
  display:inline-flex;align-items:center;gap:.6rem;
  font-size:.68rem;font-weight:600;letter-spacing:.2em;text-transform:uppercase;color:var(--gold);
  margin-bottom:1rem;
}
.s-tag::before{content:'';width:24px;height:1px;background:var(--gold)}
h2.s-title{
  font-family:'Playfair Display',serif;
  font-size:clamp(2rem,4vw,3.5rem);font-weight:700;line-height:1.1;
  color:var(--ink);margin-bottom:.8rem;
}
h2.s-title em{font-style:italic;color:var(--gold);font-weight:400}

/* ── COLLECTION GRID ── */
.collection-section{background:var(--off)}
.collection-grid{
  display:grid;grid-template-columns:repeat(3,1fr);
  gap:1.5rem;margin-top:3rem;
  perspective:1200px;
}
/* 3D product card */
.prod-card{
  position:relative;cursor:none;
  transform-style:preserve-3d;
  transition:transform .4s cubic-bezier(.25,.46,.45,.94),box-shadow .4s;
  background:var(--white);
  border:1px solid var(--border);
  overflow:hidden;
}
.prod-card:hover{
  transform:perspective(800px) rotateX(4deg) rotateY(-4deg) translateY(-10px);
  box-shadow:20px 30px 60px rgba(17,18,16,.12),0 2px 8px rgba(17,18,16,.06);
}
.prod-img{
  height:280px;display:flex;align-items:center;justify-content:center;
  position:relative;overflow:hidden;
}
/* CSS T-shirt shape */
.tshirt{
  position:relative;width:140px;
  transition:transform .4s;
}
.prod-card:hover .tshirt{transform:scale(1.05) translateZ(20px)}
.tshirt svg{width:100%;height:auto;filter:drop-shadow(0 12px 24px rgba(0,0,0,.12))}
.prod-card:hover .tshirt svg{filter:drop-shadow(0 20px 40px rgba(0,0,0,.18))}
.prod-badge{
  position:absolute;top:.9rem;left:.9rem;
  background:var(--ink);color:var(--white);
  font-size:.6rem;font-weight:600;letter-spacing:.12em;text-transform:uppercase;
  padding:.28rem .65rem;
}
.prod-badge.gold{background:var(--gold)}
.prod-info{padding:1.3rem 1.5rem 1.6rem}
.prod-cat{font-size:.65rem;font-weight:600;letter-spacing:.18em;text-transform:uppercase;color:var(--mid)}
.prod-name{font-family:'Playfair Display',serif;font-size:1.15rem;font-weight:700;color:var(--ink);margin:.3rem 0 .6rem}
.prod-desc{font-size:.78rem;color:var(--mid);line-height:1.6;font-weight:300}
.prod-footer{display:flex;align-items:center;justify-content:space-between;margin-top:1rem}
.prod-sizes{display:flex;gap:.35rem}
.sz{
  width:26px;height:26px;border:1px solid var(--border);
  display:flex;align-items:center;justify-content:center;
  font-size:.6rem;font-weight:600;color:var(--mid);
  cursor:none;transition:all .15s;
}
.sz:hover,.sz.act{background:var(--ink);border-color:var(--ink);color:#fff}
.prod-arrow{
  width:38px;height:38px;background:var(--ink);
  display:flex;align-items:center;justify-content:center;
  color:#fff;font-size:.9rem;cursor:none;
  transition:background .2s,transform .2s;
}
.prod-card:hover .prod-arrow{background:var(--gold);transform:rotate(-45deg)}

/* ── BRAND VIDEO SECTION ── */
.video-section{background:var(--ink)}
.video-inner{display:grid;grid-template-columns:1fr 1.6fr;min-height:520px}
.video-text{
  display:flex;flex-direction:column;justify-content:center;
  padding:5rem;color:var(--white);
}
.video-text .s-tag{color:var(--gold-lt)}
.video-text .s-tag::before{background:var(--gold-lt)}
.video-text h2{color:var(--white)}
.video-text p{font-size:.9rem;color:rgba(255,255,255,.45);line-height:1.8;font-weight:300;margin:1rem 0 2rem;max-width:320px}
.video-frame{
  position:relative;overflow:hidden;
}
.brand-vid{width:100%;height:100%;object-fit:cover;display:block;opacity:.85}
.vid-controls{
  position:absolute;inset:0;
  display:flex;align-items:center;justify-content:center;
  background:rgba(0,0,0,.2);
  opacity:0;transition:opacity .3s;
}
.video-frame:hover .vid-controls{opacity:1}
.play-circle{
  width:64px;height:64px;border:2px solid rgba(255,255,255,.6);
  border-radius:50%;display:flex;align-items:center;justify-content:center;
  font-size:1.2rem;color:#fff;cursor:none;
  transition:background .2s,transform .2s;
}
.play-circle:hover{background:rgba(255,255,255,.15);transform:scale(1.1)}

/* ── INSTAGRAM ── */
.ig-section{background:var(--white)}
.ig-head{
  display:flex;align-items:center;justify-content:space-between;
  flex-wrap:wrap;gap:2rem;margin-bottom:3rem;
}
.ig-profile{
  display:flex;align-items:center;gap:1.5rem;
}
.ig-ava{
  width:72px;height:72px;border-radius:50%;
  padding:2.5px;
  background:var(--ig-grad);
  display:flex;align-items:center;justify-content:center;flex-shrink:0;
}
.ig-ava-inner{
  width:100%;height:100%;border-radius:50%;
  background:var(--white);display:flex;align-items:center;justify-content:center;
  font-size:1.8rem;
}
.ig-user-name{font-family:'Playfair Display',serif;font-size:1.25rem;font-weight:700;color:var(--ink)}
.ig-handle{
  font-size:.78rem;font-weight:600;letter-spacing:.06em;
  background:var(--ig-grad);-webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text;
}
.ig-bio{font-size:.78rem;color:var(--mid);line-height:1.6;margin-top:.35rem;max-width:260px}

/* IG post grid — fashion magazine style */
.ig-grid{
  display:grid;
  grid-template-columns:repeat(4,1fr);
  grid-template-rows:220px 220px;
  gap:6px;
}
.ig-post{
  position:relative;overflow:hidden;
  text-decoration:none;cursor:none;
  display:block;
}
.ig-post:first-child{grid-column:span 2;grid-row:span 2}
.ig-post-bg{
  width:100%;height:100%;
  display:flex;align-items:center;justify-content:center;
  font-size:3.5rem;
  transition:transform .5s cubic-bezier(.25,.46,.45,.94);
}
.ig-post:first-child .ig-post-bg{font-size:6rem}
.ig-post:hover .ig-post-bg{transform:scale(1.06)}
.ig-post-overlay{
  position:absolute;inset:0;
  background:linear-gradient(to top,rgba(17,18,16,.75) 0%,transparent 55%);
  display:flex;flex-direction:column;justify-content:flex-end;
  padding:1rem;
  opacity:0;transition:opacity .3s;
}
.ig-post:hover .ig-post-overlay{opacity:1}
.ig-post-tag{font-size:.6rem;font-weight:600;letter-spacing:.15em;text-transform:uppercase;color:var(--gold-lt)}
.ig-post-cap{font-family:'Playfair Display',serif;font-size:.9rem;font-style:italic;color:#fff;margin-top:.15rem}
/* color themes for posts */
.c1{background:#f0e8d8}.c2{background:#dde8f0}.c3{background:#e8f0dd}.c4{background:#f0dde8}.c5{background:#f0eadd}.c6{background:#dde8f0}.c7{background:#e8ddf0}

.ig-cta{display:flex;align-items:center;gap:1.5rem;margin-top:2rem;flex-wrap:wrap}
.ig-note{font-size:.78rem;color:var(--mid);font-weight:300}

/* ── REVIEWS ── */
.reviews-section{background:var(--off)}
.rev-header{display:flex;align-items:flex-start;justify-content:space-between;flex-wrap:wrap;gap:2rem;margin-bottom:3rem}
.big-score{
  font-family:'Playfair Display',serif;
  font-size:6rem;font-weight:900;line-height:1;color:var(--ink);
}
.big-score span{color:var(--gold)}
.rev-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:1.2rem;perspective:1000px}
.rev-card{
  background:var(--white);border:1px solid var(--border);
  padding:1.8rem;position:relative;
  transition:transform .35s cubic-bezier(.25,.46,.45,.94),box-shadow .35s;
  transform-style:preserve-3d;
}
.rev-card:hover{
  transform:perspective(800px) rotateX(3deg) rotateY(-3deg) translateY(-8px);
  box-shadow:12px 20px 40px rgba(17,18,16,.1);
}
.rev-stars{color:var(--gold);font-size:.88rem;letter-spacing:.05em;margin-bottom:.9rem}
.rev-q{font-family:'Playfair Display',serif;font-size:2.5rem;color:var(--border);line-height:.4;display:block;margin-bottom:.5rem}
.rev-text{font-size:.84rem;color:var(--mid);line-height:1.75;font-weight:300}
.rev-author{display:flex;align-items:center;gap:.8rem;margin-top:1.2rem;padding-top:1.2rem;border-top:1px solid var(--border)}
.rev-ava{
  width:36px;height:36px;border-radius:50%;
  background:var(--ink);display:flex;align-items:center;justify-content:center;
  font-size:.78rem;font-weight:700;color:var(--white);flex-shrink:0;
}
.rev-name{font-size:.8rem;font-weight:600;color:var(--ink)}
.rev-via{font-size:.65rem;color:var(--mid);margin-top:.1rem}

/* Review form */
.rev-form{
  margin-top:2.5rem;background:var(--white);border:1px solid var(--border);
  padding:2.5rem;
}
.finp{
  width:100%;background:var(--off);border:1.5px solid var(--border);
  color:var(--ink);padding:.8rem 1.1rem;
  font-family:'Outfit',sans-serif;font-size:.85rem;outline:none;
  transition:border-color .2s;
}
.finp::placeholder{color:rgba(90,86,80,.45)}
.finp:focus{border-color:var(--gold)}
.frow{display:grid;grid-template-columns:1fr 1fr;gap:1rem;margin-bottom:1rem}
.star-pick-row{
  display:flex;align-items:center;gap:.4rem;
  background:var(--off);border:1.5px solid var(--border);padding:.6rem 1.1rem;
}
.sp{font-size:1.4rem;cursor:none;opacity:.25;color:var(--ink);transition:.15s}
.sp.on{opacity:1;color:var(--gold)}

/* ── STORE INFO ── */
.store-section{background:var(--white)}
.store-grid{display:grid;grid-template-columns:1fr 1fr;gap:5rem;margin-top:3rem;align-items:start}
.hours-list{}
.h-row{
  display:flex;justify-content:space-between;align-items:center;
  padding:.85rem 0;border-bottom:1px solid var(--border);font-size:.85rem;
}
.h-day{color:var(--mid);font-weight:400}
.h-time{color:var(--ink);font-weight:600}
.h-closed{color:var(--rust);font-weight:500}
.h-today{
  background:linear-gradient(to right,rgba(184,146,42,.06),transparent);
  padding:.85rem .6rem;margin:0 -.6rem;
  border-bottom:1px solid rgba(184,146,42,.2);
}
.today-pill{
  background:var(--gold);color:#fff;
  font-size:.58rem;font-weight:700;letter-spacing:.1em;text-transform:uppercase;
  padding:.14rem .5rem;border-radius:2px;margin-left:.5rem;
}
.contact-list{}
.c-row{display:flex;gap:1.2rem;padding:1rem 0;border-bottom:1px solid var(--border);align-items:flex-start}
.c-icon{font-size:1.1rem;flex-shrink:0;margin-top:.1rem}
.c-lbl{font-size:.63rem;font-weight:600;letter-spacing:.12em;text-transform:uppercase;color:var(--mid)}
.c-val{font-size:.88rem;font-weight:500;color:var(--ink);margin-top:.2rem}
.c-val a{color:var(--ink);text-decoration:none;transition:color .2s}
.c-val a:hover{color:var(--gold)}

/* ── MAP ── */
.map-section{position:relative}
.map-top{
  padding:4rem 5rem 2rem;
  display:flex;align-items:flex-end;justify-content:space-between;flex-wrap:wrap;gap:1.5rem;
  background:var(--ink);
}
.map-top .s-tag{color:var(--gold-lt)}
.map-top .s-tag::before{background:var(--gold-lt)}
.map-top h2{color:var(--white)}
.map-link{
  border:1.5px solid rgba(255,255,255,.2);color:rgba(255,255,255,.7);
  padding:.65rem 1.4rem;font-size:.7rem;font-weight:600;letter-spacing:.14em;text-transform:uppercase;
  text-decoration:none;transition:all .2s;display:inline-block;
}
.map-link:hover{background:var(--gold);border-color:var(--gold);color:#fff}
.map-frame{
  position:relative;height:420px;
}
.map-frame iframe{width:100%;height:100%;border:none;display:block;filter:grayscale(20%) contrast(1.05)}
.map-card{
  position:absolute;top:1.5rem;left:2rem;z-index:5;
  background:rgba(250,250,248,.96);backdrop-filter:blur(12px);
  border:1px solid var(--border);padding:1.4rem 1.8rem;min-width:240px;
  box-shadow:0 8px 30px rgba(17,18,16,.12);
}
.mc-name{font-family:'Playfair Display',serif;font-size:1.1rem;font-weight:700;color:var(--ink)}
.mc-addr{font-size:.72rem;color:var(--mid);line-height:1.6;margin-top:.3rem}
.mc-rating{display:flex;align-items:center;gap:.4rem;margin-top:.7rem;font-size:.78rem;color:var(--gold);font-weight:600}

/* ── FOOTER ── */
footer{
  background:var(--ink);color:var(--white);
  padding:5rem 5rem 2.5rem;
}
.foot-top{
  display:grid;grid-template-columns:2fr 1fr 1fr 1fr;
  gap:4rem;padding-bottom:4rem;
  border-bottom:1px solid rgba(255,255,255,.07);
}
.f-brand{font-family:'Playfair Display',serif;font-size:2rem;font-weight:900;color:var(--white);margin-bottom:.8rem}
.f-brand span{color:var(--gold)}
.f-tag{font-size:.78rem;color:rgba(255,255,255,.3);line-height:1.85;max-width:240px;font-weight:300}
.f-soc{display:flex;gap:.6rem;margin-top:1.5rem}
.f-sb{
  width:38px;height:38px;border:1px solid rgba(255,255,255,.1);
  border-radius:50%;display:flex;align-items:center;justify-content:center;
  font-size:.9rem;text-decoration:none;cursor:none;
  transition:border-color .2s,transform .2s;
}
.f-sb:hover{border-color:var(--gold);transform:translateY(-3px)}
.f-sb.f-ig:hover{background:var(--ig-grad);border-color:transparent}
