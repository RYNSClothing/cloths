<script>
/* ── CURSOR ── */
const cur=document.getElementById('cur'),ring=document.getElementById('cur-ring');
let cx=0,cy=0,rx=0,ry=0;
document.addEventListener('mousemove',e=>{cx=e.clientX;cy=e.clientY;cur.style.left=cx+'px';cur.style.top=cy+'px'});
(function lerpRing(){rx+=(cx-rx)*.12;ry+=(cy-ry)*.12;ring.style.left=rx+'px';ring.style.top=ry+'px';requestAnimationFrame(lerpRing)})();
document.querySelectorAll('a,button,.prod-card,.rev-card,.ig-post,.sz').forEach(el=>{
  el.addEventListener('mouseenter',()=>{cur.style.width='6px';cur.style.height='6px';ring.style.width='50px';ring.style.height='50px';ring.style.borderColor='rgba(184,146,42,.5)'});
  el.addEventListener('mouseleave',()=>{cur.style.width='12px';cur.style.height='12px';ring.style.width='36px';ring.style.height='36px';ring.style.borderColor='rgba(17,18,16,.3)'});
});

/* ── SIZE PICKER ── */
document.querySelectorAll('.prod-sizes').forEach(row=>{
  row.querySelectorAll('.sz').forEach(sz=>{
    sz.addEventListener('click',()=>{row.querySelectorAll('.sz').forEach(s=>s.classList.remove('act'));sz.classList.add('act')});
  });
});

/* ── 3D PRODUCT CARD TILT ── */
document.querySelectorAll('.prod-card,.rev-card').forEach(c=>{
  c.addEventListener('mousemove',e=>{
    const r=c.getBoundingClientRect();
    const x=(e.clientX-r.left)/r.width-.5;
    const y=(e.clientY-r.top)/r.height-.5;
    c.style.transform=`perspective(800px) rotateX(${-y*10}deg) rotateY(${x*10}deg) translateY(-10px) scale(1.02)`;
    c.style.boxShadow=`${x*25}px ${y*25}px 50px rgba(17,18,16,.14)`;
  });
  c.addEventListener('mouseleave',()=>{c.style.transform='';c.style.boxShadow=''});
});

/* ── VIDEO ── */
function toggleVid(){const v=document.getElementById('mainVid');v.paused?v.play():v.pause()}

/* ── SCROLL REVEAL ── */
const io=new IntersectionObserver(entries=>entries.forEach(e=>{if(e.isIntersecting){e.target.classList.add('in');io.unobserve(e.target)}}),{threshold:.12});
document.querySelectorAll('.reveal,.reveal-l,.reveal-r').forEach(el=>io.observe(el));

/* ── REVIEWS ── */
const reviewsData=[
  {t:"Product is so good material is very soft and easy to wash really like the t-shirt. RYNS clothing is a very good brand.",s:5,n:"Verified Customer",v:"Google Review",i:"V"},
  {t:"RYNS Clothing in Varanasi is my go-to for both wholesale & retail t-shirts. Quality cotton, sharp custom printing, and fair pricing.",s:5,n:"Wholesale Buyer",v:"Google Review",i:"W"},
  {t:"Perfect for someone who likes a clean, classy look. Totally worth the price — will definitely shop again.",s:5,n:"Happy Shopper",v:"Google Review",i:"H"},
  {t:"RYNS clothing brands are best in providing relaxed, trendy and comfortable clothes, with best fabric quality and durability!",s:5,n:"Loyal Customer",v:"Google Review",i:"L"},
  {t:"The product quality was okay, but the delivery took longer than promised and communication could have been better.",s:3,n:"Online Order",v:"Google Review",i:"O"}
];
let userRevs=[],starRating=0;

function renderRevs(){
  document.getElementById('revGrid').innerHTML=[...reviewsData,...userRevs].map((r,i)=>`
    <div class="rev-card" style="animation-delay:${i*.07}s">
      <div class="rev-stars">${'★'.repeat(r.s)}${'☆'.repeat(5-r.s)}</div>
      <span class="rev-q">"</span>
      <p class="rev-text">${r.t}</p>
      <div class="rev-author">
        <div class="rev-ava">${r.i}</div>
        <div><div class="rev-name">${r.n}</div><div class="rev-via">${r.v}</div></div>
      </div>
    </div>`).join('');
  document.querySelectorAll('.rev-card').forEach(c=>{
    c.addEventListener('mousemove',e=>{const r=c.getBoundingClientRect();const x=(e.clientX-r.left)/r.width-.5,y=(e.clientY-r.top)/r.height-.5;c.style.transform=`perspective(800px) rotateX(${-y*10}deg) rotateY(${x*10}deg) translateY(-8px)`;c.style.boxShadow=`${x*20}px ${y*20}px 40px rgba(17,18,16,.1)`});
    c.addEventListener('mouseleave',()=>{c.style.transform='';c.style.boxShadow=''});
  });
}

function setStar(v){starRating=v;document.querySelectorAll('.sp').forEach(s=>s.classList.toggle('on',+s.dataset.v<=v))}

function submitReview(){
  const n=document.getElementById('rName').value.trim(),t=document.getElementById('rText').value.trim();
  if(!n||!t||!starRating){alert('Please enter your name, a review, and a star rating.');return;}
  userRevs.push({t,s:starRating,n,v:'Visitor Review',i:n[0].toUpperCase()});
  document.getElementById('rName').value='';document.getElementById('rText').value='';
  setStar(0);starRating=0;renderRevs();
  document.getElementById('reviews').scrollIntoView({behavior:'smooth'});
}

renderRevs();
</script>
